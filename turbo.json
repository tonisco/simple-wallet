{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "start:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["migrate", "build"]
    },
    "migrate": {
      "cache": false,
      "dependsOn": ["^migrate"]
    }
  }
}
